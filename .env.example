# MAPE.LEGAL — Variables de entorno requeridas
# Copiar este archivo a .env.local y completar los valores antes de ejecutar la app.
# NUNCA commitear .env.local — está en .gitignore.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Enable the "Continuar con Google" button on /login. Set to "true" to show it.
# The Client ID/Secret are configured in Supabase Dashboard → Auth → Providers,
# never in this file.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mape.legal

# ─── Email — SendGrid ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=gerencia@mape.legal
SENDGRID_FROM_NAME=MAPE.LEGAL

# ─── WhatsApp — Meta Cloud API ───────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── WhatsApp — Twilio (asistente María) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── IA — Anthropic (asistente María) ────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── IA — OpenAI (embeddings para RAG semántico de María) ────────────────────
# Modelo: text-embedding-3-small (1536 dims). Sin esta key, retrieveKnowledge()
# cae automáticamente al RPC FTS (search_maria_knowledge_fts) — el flow sigue
# funcionando, sólo se degrada el recall semántico.
OPENAI_API_KEY=

# ─── Broadcast diario de precios ─────────────────────────────────────────────
# Header Bearer para proteger POST /api/broadcast/run desde cron externo.
CRON_SECRET=
# goldapi.io — precios oro/plata/cobre (free tier disponible).
GOLDAPI_KEY=
# exchangerate-api.com v6 (opcional; sin clave usa tier gratuito).
EXCHANGE_RATE_API_KEY=

# ─── Mapa 3D — MapTiler (Biblioteca Archivos Mineros) ────────────────────────
# MapTiler API Key — opcional, habilita imágenes satelitales + terreno 3D completo
# Obtener key gratuita en https://cloud.maptiler.com (100K requests/mes gratis)
# Sin key, el mapa usa tiles gratuitos OpenStreetMap + hillshade DEM
NEXT_PUBLIC_MAPTILER_KEY=
